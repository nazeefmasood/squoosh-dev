{
  "manifest_version": 3,
  "name": "Smoosh — AI image cleaner",
  "version": "0.1.0",
  "description": "Remove Gemini watermarks and compress AI-generated images right inside Gemini & ChatGPT. Runs locally — your images never leave your browser.",
  "permissions": ["downloads", "scripting", "storage"],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://*.googleusercontent.com/*",
    "https://*.oaiusercontent.com/*",
    "https://*.google.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Smoosh — AI image cleaner"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["worker.js", "gwm.js"],
      "matches": ["https://gemini.google.com/*", "https://chatgpt.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "smoosh@nazeefmasood.dev",
      "strict_min_version": "115.0"
    }
  }
}
