{
  "manifest_version": 3,
  "name": "Smoosh — AI image cleaner",
  "version": "0.1.0",
  "description": "Send AI-generated images from Gemini & ChatGPT straight to Smoosh to remove watermarks or compress. Opens the Smoosh site with your image loaded.",
  "permissions": ["activeTab", "storage", "unlimitedStorage"],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://*.googleusercontent.com/*",
    "https://*.oaiusercontent.com/*",
    "https://*.google.com/*",
    "https://smoosh-dev.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Smoosh — AI image cleaner",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://smoosh-dev.vercel.app/*"],
      "js": ["site-handoff.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "smoosh@nazeefmasood.dev",
      "strict_min_version": "128.0"
    }
  }
}
