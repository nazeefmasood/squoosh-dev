{
  "headers": [
    {
      "source": "**/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    }
  ],
  "redirects": [],
  "rewrites": [
    { "source": "/editor", "destination": "/index.html" },
    { "source": "/watermark", "destination": "/index.html" },
    { "source": "/batch", "destination": "/index.html" }
  ]
}
